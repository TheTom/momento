#!/usr/bin/env bash
# Copyright (c) 2026 Tom Turney
# SPDX-License-Identifier: Apache-2.0

# Git pre-push hook: license headers, tests, and coverage >= 95%.
# Install: cp hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# Or run: ./setup.sh (registers automatically)

set -euo pipefail

MIN_COVERAGE=95
LICENSE_HEADER="SPDX-License-Identifier: Apache-2.0"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"

# ---------- License header check (always runs) ----------
echo -e "${CYAN}[pre-push]${NC} Checking license headers..."
MISSING=""
while IFS= read -r -d '' file; do
    if ! head -5 "$file" | grep -q "$LICENSE_HEADER"; then
        MISSING="$MISSING  $file\n"
    fi
done < <(find "$REPO_ROOT/src" "$REPO_ROOT/tests" "$REPO_ROOT/hooks" -type f \( -name '*.py' -o -name '*.sh' \) -print0 2>/dev/null)
# Also check setup.sh at root
if [[ -f "$REPO_ROOT/setup.sh" ]] && ! head -5 "$REPO_ROOT/setup.sh" | grep -q "$LICENSE_HEADER"; then
    MISSING="$MISSING  setup.sh\n"
fi
if [[ -n "$MISSING" ]]; then
    echo -e "${RED}[pre-push]${NC} Missing SPDX license header:"
    echo -e "$MISSING"
    echo -e "${RED}[pre-push]${NC} Push blocked. Add '# $LICENSE_HEADER' to the top of each file."
    exit 1
fi
echo -e "${GREEN}[pre-push]${NC} All source files have license headers."

# ---------- Skip tests if only docs/non-code files changed ----------
CHANGED_FILES=$(git diff --name-only "origin/$(git rev-parse --abbrev-ref HEAD)..HEAD" 2>/dev/null || git diff --name-only HEAD~1..HEAD 2>/dev/null || echo "")
if [[ -n "$CHANGED_FILES" ]]; then
    CODE_FILES=$(echo "$CHANGED_FILES" | grep -vE '\.(md|txt|html|css|json)$|^docs/|^\.gitignore$|^LICENSE$|^README' || true)
    if [[ -z "$CODE_FILES" ]]; then
        echo -e "${GREEN}[pre-push]${NC} Only docs/config changed — skipping tests."
        exit 0
    fi
fi

# ---------- Tests + coverage ----------
echo -e "${CYAN}[pre-push]${NC} Running tests with coverage check..."

# Find python — prefer project venv, fall back to PATH
if [[ -x "$REPO_ROOT/.venv/bin/python3" ]]; then
    PY="$REPO_ROOT/.venv/bin/python3"
elif command -v python3 &>/dev/null; then
    PY="python3"
else
    echo -e "${RED}[pre-push]${NC} Python not found. Aborting push."
    exit 1
fi

# Run tests with coverage
OUTPUT=$("$PY" -m pytest "$REPO_ROOT/tests/" \
    --cov=momento \
    --cov-report=term-missing \
    --cov-fail-under="$MIN_COVERAGE" \
    -q 2>&1) || {
    echo -e "${RED}[pre-push]${NC} Tests failed or coverage below ${MIN_COVERAGE}%."
    echo ""
    echo "$OUTPUT"
    echo ""
    echo -e "${RED}[pre-push]${NC} Push blocked. Fix tests and/or coverage before pushing."
    exit 1
}

# Extract coverage percentage from output
COVERAGE=$(echo "$OUTPUT" | grep "^TOTAL" | awk '{print $NF}' | tr -d '%')

echo -e "${GREEN}[pre-push]${NC} All tests passed. Coverage: ${COVERAGE}% (minimum: ${MIN_COVERAGE}%)"
exit 0
